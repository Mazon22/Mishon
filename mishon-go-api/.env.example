PORT=8081
DATABASE_URL=postgres://mishon:CHANGE_ME@localhost:5432/mishon?sslmode=disable
JWT_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ISSUER=Mishon
JWT_AUDIENCE=MishonUsers
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_DAYS=30
PUBLIC_BASE_URL=http://localhost:8081
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*,https://localhost:*,https://127.0.0.1:*
WEB_DIST_DIR=../mishon-web/dist

# SMTP is optional in local development. When SMTP is not configured,
# verification and reset links are written to backend logs instead.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost

# Legacy fallback only for old /uploads links. New media is stored in PostgreSQL.
UPLOADS_DIR=
